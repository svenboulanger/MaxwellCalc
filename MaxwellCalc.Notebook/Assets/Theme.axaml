<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        xmlns:controls="using:MaxwellCalc.Notebook.Controls">
	<!--
	  Step 2 — Design tokens & theming resources.

	  Every color from REDESIGN_UI.md → Design Tokens is exposed as a named brush inside a
	  ThemeVariant dictionary (Light / Dark) so it resolves via {DynamicResource} and recolors
	  live when Application.Current.RequestedThemeVariant changes.

	  rgba(...) values are expressed as #AARRGGBB (alpha byte first). oklch(...) values are
	  precomputed to sRGB hex (Avalonia's parser does not accept oklch); the source oklch is kept
	  in a comment next to each so the intent stays auditable.

	  Theme-invariant tokens (radii, spacing, fonts, pill styles) live at the bottom, outside the
	  theme dictionaries.
	-->
	<Styles.Resources>
		<ResourceDictionary>
			<ResourceDictionary.ThemeDictionaries>

				<!-- ============================ LIGHT ============================ -->
				<ResourceDictionary x:Key="Light">
					<SolidColorBrush x:Key="BgBrush" Color="#eeece7" />
					<SolidColorBrush x:Key="SurfBrush" Color="#faf9f6" />
					<SolidColorBrush x:Key="BarBrush" Color="#f1efe9" />
					<SolidColorBrush x:Key="BarFooterBrush" Color="#f4f2ec" />
					<SolidColorBrush x:Key="InkBrush" Color="#1c1c1a" />
					<SolidColorBrush x:Key="MutBrush" Color="#80000000" />       <!-- rgba(0,0,0,.5) -->
					<SolidColorBrush x:Key="FaintBrush" Color="#57000000" />     <!-- rgba(0,0,0,.34) -->
					<SolidColorBrush x:Key="LineBrush" Color="#12000000" />      <!-- rgba(0,0,0,.07) -->
					<SolidColorBrush x:Key="CardBrush" Color="#ffffff" />
					<SolidColorBrush x:Key="ChipBrush" Color="#ffffff" />
					<SolidColorBrush x:Key="ChipBorderBrush" Color="#14000000" /><!-- rgba(0,0,0,.08) -->
					<SolidColorBrush x:Key="ActiveTintBrush" Color="#0D2A78D6" /><!-- rgba(42,120,214,.05) -->
					<SolidColorBrush x:Key="ErrBrush" Color="#B33736" />         <!-- oklch(0.52 0.16 25) -->
					<SolidColorBrush x:Key="OverlayBrush" Color="#29141412" />   <!-- rgba(20,20,18,.16) -->
					<SolidColorBrush x:Key="AccentBrush" Color="#1666AA" />      <!-- oklch(0.5 0.13 250) -->
					<SolidColorBrush x:Key="ConstPillBackground" Color="#1A2A78D6" /><!-- rgba(42,120,214,.1) -->

					<!-- Unit-hue presets: oklch(0.52 0.13 H). Wash = same hue at ~0.12 alpha. -->
					<SolidColorBrush x:Key="UnitHueAmberBrush" Color="#9D5300" />   <!-- H=60 -->
					<SolidColorBrush x:Key="UnitHueGreenBrush" Color="#1D7D3E" />   <!-- H=150 -->
					<SolidColorBrush x:Key="UnitHueVioletBrush" Color="#7555A8" />  <!-- H=300 -->
					<SolidColorBrush x:Key="UnitHueAmberWashBrush" Color="#1F9D5300" />
					<SolidColorBrush x:Key="UnitHueGreenWashBrush" Color="#1F1D7D3E" />
					<SolidColorBrush x:Key="UnitHueVioletWashBrush" Color="#1F7555A8" />

					<!-- Active unit hue: repointed by SettingsViewModel (Step 10); defaults to amber. -->
					<SolidColorBrush x:Key="UnitHueBrush" Color="#9D5300" />
					<SolidColorBrush x:Key="UnitHueWashBrush" Color="#1F9D5300" />
				</ResourceDictionary>

				<!-- ============================ DARK ============================ -->
				<ResourceDictionary x:Key="Dark">
					<SolidColorBrush x:Key="BgBrush" Color="#141417" />
					<SolidColorBrush x:Key="SurfBrush" Color="#1b1b20" />
					<SolidColorBrush x:Key="BarBrush" Color="#191920" />
					<SolidColorBrush x:Key="BarFooterBrush" Color="#1e1e25" />
					<SolidColorBrush x:Key="InkBrush" Color="#ececeb" />
					<SolidColorBrush x:Key="MutBrush" Color="#70FFFFFF" />       <!-- rgba(255,255,255,.44) -->
					<SolidColorBrush x:Key="FaintBrush" Color="#4DFFFFFF" />     <!-- rgba(255,255,255,.3) -->
					<SolidColorBrush x:Key="LineBrush" Color="#14FFFFFF" />      <!-- rgba(255,255,255,.08) -->
					<SolidColorBrush x:Key="CardBrush" Color="#22222a" />
					<SolidColorBrush x:Key="ChipBrush" Color="#26262e" />
					<SolidColorBrush x:Key="ChipBorderBrush" Color="#1AFFFFFF" /><!-- rgba(255,255,255,.1) -->
					<SolidColorBrush x:Key="ActiveTintBrush" Color="#1278AAFF" /><!-- rgba(120,170,255,.07) -->
					<SolidColorBrush x:Key="ErrBrush" Color="#F7857D" />         <!-- oklch(0.74 0.14 25) -->
					<SolidColorBrush x:Key="OverlayBrush" Color="#80000000" />   <!-- rgba(0,0,0,.5) -->
					<SolidColorBrush x:Key="AccentBrush" Color="#67B0F9" />      <!-- oklch(0.74 0.13 250) -->
					<SolidColorBrush x:Key="ConstPillBackground" Color="#2978AAFF" /><!-- rgba(120,170,255,.16) -->

					<!-- Unit-hue presets: oklch(0.82 0.11 H). Wash = same hue at ~0.16 alpha. -->
					<SolidColorBrush x:Key="UnitHueAmberBrush" Color="#F9B379" />   <!-- H=60 -->
					<SolidColorBrush x:Key="UnitHueGreenBrush" Color="#8FD89E" />   <!-- H=150 -->
					<SolidColorBrush x:Key="UnitHueVioletBrush" Color="#CFB4FF" />  <!-- H=300 -->
					<SolidColorBrush x:Key="UnitHueAmberWashBrush" Color="#29F9B379" />
					<SolidColorBrush x:Key="UnitHueGreenWashBrush" Color="#298FD89E" />
					<SolidColorBrush x:Key="UnitHueVioletWashBrush" Color="#29CFB4FF" />

					<!-- Active unit hue: repointed by SettingsViewModel (Step 10); defaults to amber. -->
					<SolidColorBrush x:Key="UnitHueBrush" Color="#F9B379" />
					<SolidColorBrush x:Key="UnitHueWashBrush" Color="#29F9B379" />
				</ResourceDictionary>

			</ResourceDictionary.ThemeDictionaries>

			<!-- ===================== THEME-INVARIANT TOKENS ===================== -->

			<!-- Typography. UI = platform sans; mono is shared by the editor AND the result gutter
			     so digits line up (identical family + metrics). IBM Plex is not bundled (see plan
			     Step 2 fallback); Cascadia Code / Consolas are the desktop substitutes. -->
			<FontFamily x:Key="UiFontFamily">Segoe UI, San Francisco, Helvetica Neue, Arial</FontFamily>
			<FontFamily x:Key="MonoFontFamily">Cascadia Code, Cascadia Mono, Consolas, Courier New</FontFamily>

			<!-- Radii -->
			<CornerRadius x:Key="AppMarkCornerRadius">4</CornerRadius>
			<CornerRadius x:Key="PillCornerRadius">5</CornerRadius>
			<CornerRadius x:Key="FuncPillCornerRadius">6</CornerRadius>
			<CornerRadius x:Key="InputCornerRadius">6</CornerRadius>
			<CornerRadius x:Key="ChipCornerRadius">7</CornerRadius>
			<CornerRadius x:Key="ButtonCornerRadius">7</CornerRadius>
			<CornerRadius x:Key="CardCornerRadius">14</CornerRadius>
			<!-- Bottom-only radius so the palette footer follows the card's rounded corners. -->
			<CornerRadius x:Key="CardFooterCornerRadius">0,0,14,14</CornerRadius>

			<!-- Spacing (Thickness = "left,top,right,bottom"; here "H,V" for symmetric padding) -->
			<Thickness x:Key="RowPadding">26,8</Thickness>
			<Thickness x:Key="AccessBarPadding">16,10</Thickness>
			<Thickness x:Key="OverlayPadding">8,6</Thickness>
			<Thickness x:Key="HeaderPadding">18,14</Thickness>
			<Thickness x:Key="AddRowPadding">16,11</Thickness>

			<!-- Gaps / metrics -->
			<sys:Double x:Key="EditorGutterGap">24</sys:Double>
			<sys:Double x:Key="ChipGap">9</sys:Double>
			<sys:Double x:Key="TitleBarHeight">44</sys:Double>
			<sys:Double x:Key="EditorFontSize">15</sys:Double>

			<!-- Overlay drop shadow: 0 30px 70px -20px rgba(0,0,0,.5) -->
			<BoxShadows x:Key="OverlayShadow">0 30 70 -20 #80000000</BoxShadows>

			<!-- ===================== CHIP CONTROL THEME ===================== -->
			<!-- Access-bar chip: leading mono glyph (caller-colored) + sans label + optional faint
			     count. inline-flex, gap 6, padding 5px 11px, radius 7, chip bg, 1px chipBorder. -->
			<ControlTheme x:Key="{x:Type controls:Chip}" TargetType="controls:Chip">
				<Setter Property="Background" Value="{DynamicResource ChipBrush}" />
				<Setter Property="BorderBrush" Value="{DynamicResource ChipBorderBrush}" />
				<Setter Property="BorderThickness" Value="1" />
				<Setter Property="CornerRadius" Value="{DynamicResource ChipCornerRadius}" />
				<Setter Property="Cursor" Value="Hand" />
				<Setter Property="Template">
					<ControlTemplate>
						<Border Background="{TemplateBinding Background}"
								BorderBrush="{TemplateBinding BorderBrush}"
								BorderThickness="{TemplateBinding BorderThickness}"
								CornerRadius="{TemplateBinding CornerRadius}"
								Padding="11,5">
							<StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
								<TextBlock Text="{TemplateBinding Glyph}"
										   FontFamily="{DynamicResource MonoFontFamily}"
										   FontStyle="{TemplateBinding GlyphFontStyle}"
										   Foreground="{TemplateBinding GlyphForeground}"
										   FontSize="12"
										   VerticalAlignment="Center" />
								<TextBlock Text="{TemplateBinding Label}"
										   FontFamily="{DynamicResource UiFontFamily}"
										   FontSize="12" FontWeight="Medium"
										   Foreground="{DynamicResource InkBrush}"
										   VerticalAlignment="Center" />
								<TextBlock Text="{TemplateBinding Count}"
										   FontFamily="{DynamicResource UiFontFamily}"
										   FontSize="12"
										   Foreground="{DynamicResource FaintBrush}"
										   VerticalAlignment="Center"
										   IsVisible="{Binding Count, RelativeSource={RelativeSource TemplatedParent}, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
							</StackPanel>
						</Border>
					</ControlTemplate>
				</Setter>
			</ControlTheme>

			<!-- ===================== QUANTITY VIEW THEME ===================== -->
			<!-- Result-gutter quantity renderer: shared mono metrics with the editor so digits line up,
			     600 weight, right-aligned. Scalar in the accent color; unit symbols in the unit hue. -->
			<ControlTheme x:Key="{x:Type controls:QuantityView}" TargetType="controls:QuantityView">
				<Setter Property="FontFamily" Value="{DynamicResource MonoFontFamily}" />
				<Setter Property="FontSize" Value="{DynamicResource EditorFontSize}" />
				<Setter Property="FontWeight" Value="SemiBold" />
				<Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
				<Setter Property="UnitForeground" Value="{DynamicResource UnitHueBrush}" />
				<Setter Property="Template">
					<ControlTemplate>
						<TextBlock Name="PART_Text" TextAlignment="Right" VerticalAlignment="Center" />
					</ControlTemplate>
				</Setter>
			</ControlTheme>

			<!-- Chrome-less TextBox theme for the editor surface inside the HighlightedExpressionBox:
			     strips the border/background in every state so only the caret and selection show over
			     the colored backdrop. Kept as its own theme because a ControlTheme's nested styles may
			     cross only one template boundary. -->
			<ControlTheme x:Key="EditorTextBoxTheme" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
				<Style Selector="^ /template/ Border#PART_BorderElement">
					<Setter Property="Background" Value="Transparent" />
					<Setter Property="BorderThickness" Value="0" />
				</Style>
				<Style Selector="^:pointerover /template/ Border#PART_BorderElement">
					<Setter Property="Background" Value="Transparent" />
					<Setter Property="BorderThickness" Value="0" />
				</Style>
				<Style Selector="^:focus /template/ Border#PART_BorderElement">
					<Setter Property="Background" Value="Transparent" />
					<Setter Property="BorderThickness" Value="0" />
				</Style>
			</ControlTheme>

			<!-- ================= HIGHLIGHTED EXPRESSION BOX THEME ================= -->
			<!-- Inline-highlighting editor: a colored TextBlock (PART_Display) rebuilt from the lexer,
			     with a transparent-text TextBox (PART_Editor) layered on top for the caret, selection
			     and real text editing. Both share the mono family/size so the highlight aligns exactly
			     with the caret. Token brushes below feed HighlightedExpressionBox.Classify. -->
			<ControlTheme x:Key="{x:Type controls:HighlightedExpressionBox}" TargetType="controls:HighlightedExpressionBox">
				<Setter Property="FontFamily" Value="{DynamicResource MonoFontFamily}" />
				<Setter Property="FontSize" Value="{DynamicResource EditorFontSize}" />
				<Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
				<Setter Property="UnitForeground" Value="{DynamicResource UnitHueBrush}" />
				<Setter Property="KeywordForeground" Value="{DynamicResource AccentBrush}" />
				<Setter Property="PunctuationForeground" Value="{DynamicResource FaintBrush}" />
				<Setter Property="UnknownForeground" Value="{DynamicResource ErrBrush}" />
				<Setter Property="VerticalAlignment" Value="Center" />
				<Setter Property="Template">
					<ControlTemplate>
						<Grid>
							<!-- Colored, non-interactive backdrop rebuilt on each keystroke. -->
							<TextBlock Name="PART_Display"
									   FontFamily="{TemplateBinding FontFamily}"
									   FontSize="{TemplateBinding FontSize}"
									   TextWrapping="NoWrap"
									   VerticalAlignment="Center" />
							<!-- Real editable surface: text transparent (the backdrop shows the color),
							     caret = accent, selection = a translucent wash so the colors show through. -->
							<TextBox Name="PART_Editor"
									 Theme="{StaticResource EditorTextBoxTheme}"
									 Text="{Binding Text, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
									 CaretIndex="{Binding CaretIndex, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
									 FontFamily="{TemplateBinding FontFamily}"
									 FontSize="{TemplateBinding FontSize}"
									 Foreground="Transparent"
									 CaretBrush="{DynamicResource AccentBrush}"
									 SelectionBrush="{DynamicResource TextControlSelectionHighlightColor}"
									 SelectionForegroundBrush="Transparent"
									 Background="Transparent"
									 BorderThickness="0"
									 Padding="0"
									 MinHeight="0"
									 AcceptsReturn="False"
									 VerticalAlignment="Center"
									 VerticalContentAlignment="Center" />
						</Grid>
					</ControlTemplate>
				</Setter>
			</ControlTheme>
		</ResourceDictionary>
	</Styles.Resources>

	<!-- ===================== SHARED PILL STYLES ===================== -->

	<!-- const pill: accent text on a translucent accent wash; 10px sans 500, radius 5, pad 2px 7px. -->
	<Style Selector="Border.constPill">
		<Setter Property="Background" Value="{DynamicResource ConstPillBackground}" />
		<Setter Property="CornerRadius" Value="{DynamicResource PillCornerRadius}" />
		<Setter Property="Padding" Value="7,2" />
		<Setter Property="VerticalAlignment" Value="Center" />
	</Style>
	<Style Selector="Border.constPill > TextBlock">
		<Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
		<Setter Property="FontFamily" Value="{DynamicResource UiFontFamily}" />
		<Setter Property="FontSize" Value="10" />
		<Setter Property="FontWeight" Value="Medium" />
	</Style>

	<!-- ƒ-defined / auto pill: unit-hue text on a faint unit-hue wash; 10.5px sans 500, radius 6, pad 2px 8px. -->
	<Style Selector="Border.funcPill">
		<Setter Property="Background" Value="{DynamicResource UnitHueWashBrush}" />
		<Setter Property="CornerRadius" Value="{DynamicResource FuncPillCornerRadius}" />
		<Setter Property="Padding" Value="8,2" />
		<Setter Property="VerticalAlignment" Value="Center" />
	</Style>
	<Style Selector="Border.funcPill > TextBlock">
		<Setter Property="Foreground" Value="{DynamicResource UnitHueBrush}" />
		<Setter Property="FontFamily" Value="{DynamicResource UiFontFamily}" />
		<Setter Property="FontSize" Value="10.5" />
		<Setter Property="FontWeight" Value="Medium" />
	</Style>
</Styles>
