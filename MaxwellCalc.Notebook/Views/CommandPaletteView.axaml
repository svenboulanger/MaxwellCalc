<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MaxwellCalc.Notebook.ViewModels"
             xmlns:overlay="using:MaxwellCalc.Notebook.ViewModels.Overlay"
             xmlns:controls="using:MaxwellCalc.Notebook.Controls"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="820" d:DesignHeight="620"
             x:Class="MaxwellCalc.Notebook.Views.CommandPaletteView"
             x:DataType="vm:CommandPaletteViewModel">

	<!-- Step 8 — the command palette overlay. A dimmed full-window scrim (closes on click) with a
	     centered card: search header, a scrolling body whose content depends on the active section, and
	     the segmented Input/Output tabs inside the Units section.
	     Step 9 — the row × buttons remove user items, and the footer add-row (one form per section/tab)
	     adds constants, input/output units and functions against the Core API, surfacing any diagnostic
	     inline. Read-only rows (built-ins, from-sheet) show no × and have no add form. Variables are
	     defined on the sheet, not here, so the Variables & constants footer adds a constant. -->
	<UserControl.Styles>
		<!-- Section label: uppercase-ish faint caption above each list. -->
		<Style Selector="TextBlock.sectionLabel">
			<Setter Property="FontFamily" Value="{DynamicResource UiFontFamily}" />
			<Setter Property="FontSize" Value="10.5" />
			<Setter Property="FontWeight" Value="SemiBold" />
			<Setter Property="Foreground" Value="{DynamicResource FaintBrush}" />
			<Setter Property="Margin" Value="0,14,0,7" />
		</Style>

		<!-- Row caption under a units list. -->
		<Style Selector="TextBlock.rowCaption">
			<Setter Property="FontFamily" Value="{DynamicResource UiFontFamily}" />
			<Setter Property="FontSize" Value="11" />
			<Setter Property="Foreground" Value="{DynamicResource FaintBrush}" />
			<Setter Property="Margin" Value="0,2,0,8" />
		</Style>

		<!-- Empty-state text. -->
		<Style Selector="TextBlock.emptyState">
			<Setter Property="FontFamily" Value="{DynamicResource UiFontFamily}" />
			<Setter Property="FontSize" Value="12.5" />
			<Setter Property="Foreground" Value="{DynamicResource MutBrush}" />
			<Setter Property="TextWrapping" Value="Wrap" />
			<Setter Property="Margin" Value="0,2,0,6" />
		</Style>

		<!-- A row: baseline-ish grid, subtle hover, hairline separator. -->
		<Style Selector="Border.paletteRow">
			<Setter Property="Padding" Value="4,7" />
			<Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
			<Setter Property="BorderThickness" Value="0,0,0,1" />
			<Setter Property="Background" Value="Transparent" />
		</Style>

		<!-- Monospace text used for names / symbols / signatures / definitions. -->
		<Style Selector="TextBlock.mono">
			<Setter Property="FontFamily" Value="{DynamicResource MonoFontFamily}" />
			<Setter Property="FontSize" Value="13.5" />
			<Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
			<Setter Property="VerticalAlignment" Value="Center" />
		</Style>

		<!-- Sans description / secondary text. -->
		<Style Selector="TextBlock.desc">
			<Setter Property="FontFamily" Value="{DynamicResource UiFontFamily}" />
			<Setter Property="FontSize" Value="12" />
			<Setter Property="Foreground" Value="{DynamicResource MutBrush}" />
			<Setter Property="TextWrapping" Value="Wrap" />
			<Setter Property="VerticalAlignment" Value="Center" />
		</Style>

		<!-- "from sheet" tag. -->
		<Style Selector="Border.fromSheet">
			<Setter Property="Background" Value="{DynamicResource ChipBrush}" />
			<Setter Property="BorderBrush" Value="{DynamicResource ChipBorderBrush}" />
			<Setter Property="BorderThickness" Value="1" />
			<Setter Property="CornerRadius" Value="{DynamicResource PillCornerRadius}" />
			<Setter Property="Padding" Value="6,1" />
			<Setter Property="VerticalAlignment" Value="Center" />
		</Style>
		<Style Selector="Border.fromSheet > TextBlock">
			<Setter Property="FontFamily" Value="{DynamicResource UiFontFamily}" />
			<Setter Property="FontSize" Value="9.5" />
			<Setter Property="Foreground" Value="{DynamicResource FaintBrush}" />
		</Style>

		<!-- × remove button. -->
		<Style Selector="Button.remove">
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="Padding" Value="4" />
			<Setter Property="CornerRadius" Value="5" />
			<Setter Property="VerticalAlignment" Value="Center" />
			<Setter Property="Foreground" Value="{DynamicResource FaintBrush}" />
		</Style>
		<Style Selector="Button.remove:pointerover">
			<Setter Property="Foreground" Value="{DynamicResource ErrBrush}" />
		</Style>

		<!-- Ghost icon button for the ✎ rename pencil in a category header. -->
		<Style Selector="Button.headerIcon">
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="Padding" Value="3" />
			<Setter Property="CornerRadius" Value="5" />
			<Setter Property="VerticalAlignment" Value="Center" />
			<Setter Property="Foreground" Value="{DynamicResource FaintBrush}" />
		</Style>
		<Style Selector="Button.headerIcon:pointerover">
			<Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
		</Style>

		<!-- Segmented Input/Output tab buttons. -->
		<Style Selector="Button.tab">
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="CornerRadius" Value="5" />
			<Setter Property="Padding" Value="12,5" />
			<Setter Property="FontFamily" Value="{DynamicResource UiFontFamily}" />
			<Setter Property="FontSize" Value="12" />
			<Setter Property="FontWeight" Value="Medium" />
			<Setter Property="Foreground" Value="{DynamicResource MutBrush}" />
		</Style>
		<!-- Active tab: accent pill with white text, matching the Add button. Template overrides lock the
		     accent through the hover state so FluentTheme's pointerover brush doesn't wash it out. -->
		<Style Selector="Button.tab.active">
			<Setter Property="Background" Value="{DynamicResource AccentBrush}" />
			<Setter Property="Foreground" Value="White" />
		</Style>
		<Style Selector="Button.tab.active /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="{DynamicResource AccentBrush}" />
			<Setter Property="Foreground" Value="White" />
		</Style>
		<Style Selector="Button.tab.active:pointerover /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="{DynamicResource AccentBrush}" />
			<Setter Property="Foreground" Value="White" />
		</Style>

		<!-- ===================== Footer add-row (Step 9) ===================== -->
		<!-- Footer container: pinned below the body with a hairline top border. -->
		<Style Selector="Border.addRow">
			<Setter Property="Background" Value="{DynamicResource BarFooterBrush}" />
			<Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
			<Setter Property="BorderThickness" Value="0,1,0,0" />
			<Setter Property="Padding" Value="{DynamicResource AddRowPadding}" />
			<Setter Property="CornerRadius" Value="{DynamicResource CardFooterCornerRadius}" />
		</Style>

		<!-- "＋ New …" label. -->
		<Style Selector="TextBlock.addLabel">
			<Setter Property="FontFamily" Value="{DynamicResource UiFontFamily}" />
			<Setter Property="FontSize" Value="12" />
			<Setter Property="FontWeight" Value="Medium" />
			<Setter Property="Foreground" Value="{DynamicResource MutBrush}" />
			<Setter Property="VerticalAlignment" Value="Center" />
		</Style>

		<!-- A mono input field in the add-row. -->
		<Style Selector="TextBox.addField">
			<Setter Property="FontFamily" Value="{DynamicResource MonoFontFamily}" />
			<Setter Property="FontSize" Value="13" />
			<Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
			<Setter Property="Background" Value="{DynamicResource CardBrush}" />
			<Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
			<Setter Property="BorderThickness" Value="1" />
			<Setter Property="CornerRadius" Value="{DynamicResource InputCornerRadius}" />
			<Setter Property="Padding" Value="7,4" />
			<Setter Property="MinHeight" Value="0" />
			<Setter Property="VerticalAlignment" Value="Center" />
			<Setter Property="VerticalContentAlignment" Value="Center" />
		</Style>
		<!-- Suppress FluentTheme's hover/focus border highlight so the field border stays quiet while
		     editing. Thickness is kept (transparent) so the content never shifts by a pixel. -->
		<Style Selector="TextBox.addField:pointerover /template/ Border#PART_BorderElement">
			<Setter Property="BorderBrush" Value="Transparent" />
		</Style>
		<Style Selector="TextBox.addField:focus /template/ Border#PART_BorderElement">
			<Setter Property="BorderBrush" Value="Transparent" />
		</Style>

		<!-- Header search box: chrome-less in every state. FluentTheme's focus style forces a border
		     thickness back onto the template part and swaps in a darker fill (TextControlBackground*),
		     so strip thickness, border brush and background on hover/focus. -->
		<Style Selector="TextBox#PART_Search:pointerover /template/ Border#PART_BorderElement">
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="BorderBrush" Value="Transparent" />
			<Setter Property="Background" Value="Transparent" />
		</Style>
		<Style Selector="TextBox#PART_Search:focus /template/ Border#PART_BorderElement">
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="BorderBrush" Value="Transparent" />
			<Setter Property="Background" Value="Transparent" />
		</Style>

		<!-- The "=" separator between the two fields. -->
		<Style Selector="TextBlock.addSeparator">
			<Setter Property="FontFamily" Value="{DynamicResource MonoFontFamily}" />
			<Setter Property="FontSize" Value="13" />
			<Setter Property="Foreground" Value="{DynamicResource FaintBrush}" />
			<Setter Property="VerticalAlignment" Value="Center" />
		</Style>

		<!-- Accent Add button. -->
		<Style Selector="Button.add">
			<Setter Property="Background" Value="{DynamicResource AccentBrush}" />
			<Setter Property="Foreground" Value="White" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="CornerRadius" Value="{DynamicResource InputCornerRadius}" />
			<Setter Property="Padding" Value="14,6" />
			<Setter Property="FontFamily" Value="{DynamicResource UiFontFamily}" />
			<Setter Property="FontSize" Value="12" />
			<Setter Property="FontWeight" Value="SemiBold" />
			<Setter Property="VerticalAlignment" Value="Center" />
		</Style>
		<Style Selector="Button.add /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="{DynamicResource AccentBrush}" />
		</Style>
		<Style Selector="Button.add:pointerover /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="{DynamicResource AccentBrush}" />
		</Style>

		<!-- Inline error line shown under a failed add. -->
		<Style Selector="TextBlock.addError">
			<Setter Property="FontFamily" Value="{DynamicResource UiFontFamily}" />
			<Setter Property="FontSize" Value="11.5" />
			<Setter Property="Foreground" Value="{DynamicResource ErrBrush}" />
			<Setter Property="TextWrapping" Value="Wrap" />
			<Setter Property="Margin" Value="0,8,0,0" />
		</Style>
	</UserControl.Styles>

	<!-- Full-window scrim. Closes when clicked directly (handled in code-behind); hidden when closed. -->
	<Border Name="Scrim"
			IsVisible="{Binding PaletteOpen}"
			Background="{DynamicResource OverlayBrush}"
			PointerPressed="OnScrimPressed">

		<!-- Inset frame: reserves the outer gap so the card can bind its MaxHeight to the frame (the gap
		     already subtracted) and never overflow the window bottom. -->
		<Grid Name="Frame" Margin="24,40">

			<!-- Centered card: stretches up to 640px wide (so it shrinks on narrow windows). Its height is
			     fixed (not sized to the item count) so the palette doesn't resize as the filter changes;
			     the body scrolls within it. Clamped by the frame height so it still fits a small window. -->
			<Border MaxWidth="640"
					Height="520"
					MaxHeight="{Binding #Frame.Bounds.Height}"
					HorizontalAlignment="Stretch" VerticalAlignment="Center"
					Background="{DynamicResource CardBrush}"
					CornerRadius="{DynamicResource CardCornerRadius}"
					BoxShadow="{DynamicResource OverlayShadow}">
				<Grid RowDefinitions="Auto,*,Auto">

				<!-- ============================ HEADER ============================ -->
				<Border Grid.Row="0" Padding="{DynamicResource HeaderPadding}"
						BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,0,1">
					<Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
						<materialIcons:MaterialIcon Grid.Column="0" Kind="Magnify"
													Width="18" Height="18"
													Foreground="{DynamicResource MutBrush}"
													VerticalAlignment="Center" />
						<TextBox Grid.Column="1" Name="PART_Search"
								 Text="{Binding Search, Mode=TwoWay}"
								 PlaceholderText="{Binding SearchPlaceholder}"
								 FontFamily="{DynamicResource MonoFontFamily}"
								 FontSize="15"
								 Foreground="{DynamicResource InkBrush}"
								 Background="Transparent"
								 BorderThickness="0"
								 Padding="0"
								 VerticalAlignment="Center"
								 VerticalContentAlignment="Center" />
						<TextBlock Grid.Column="2" Text="{Binding SectionTitle}"
								   FontFamily="{DynamicResource UiFontFamily}"
								   FontSize="11" FontWeight="SemiBold"
								   Foreground="{DynamicResource FaintBrush}"
								   VerticalAlignment="Center" />
					</Grid>
				</Border>

				<!-- ============================ BODY ============================ -->
				<!-- Each section owns its own scroll region rather than sharing one outer ScrollViewer, so the
				     card's bounded height flows down into the list — a VirtualizingStackPanel needs a bounded
				     viewport, which a shared ScrollViewer's infinite content measure would deny. Content is
				     inset with a Margin (not ScrollViewer.Padding, which is excluded from the scroll extent, so
				     padding there would clip the last rows). -->
				<Panel Grid.Row="1">

					<!-- ==================== VARIABLES & CONSTANTS ==================== -->
					<ScrollViewer IsVisible="{Binding IsVariables}" HorizontalScrollBarVisibility="Disabled">
						<StackPanel Margin="{DynamicResource AddRowPadding}">
							<TextBlock Classes="sectionLabel" Text="VARIABLES — YOU DEFINE THESE" />
							<TextBlock Classes="emptyState"
									   IsVisible="{Binding Variables.IsEmpty}"
									   Text="None yet — assign one on a line like `mass = 70 kg`." />
							<ItemsControl ItemsSource="{Binding Variables.Items}">
								<ItemsControl.ItemTemplate>
									<DataTemplate x:DataType="overlay:VariableItem">
										<Border Classes="paletteRow">
											<Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
												<StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
															VerticalAlignment="Center">
													<TextBlock Classes="mono" FontWeight="SemiBold" Text="{Binding Name}" />
													<Border Classes="fromSheet" IsVisible="{Binding FromSheet}">
														<TextBlock Text="from sheet" />
													</Border>
												</StackPanel>
												<controls:QuantityView Grid.Column="1" Value="{Binding Value}"
																	   VerticalAlignment="Center" />
												<Button Grid.Column="2" Classes="remove" IsVisible="{Binding CanRemove}"
														Command="{Binding ((vm:CommandPaletteViewModel)DataContext).Variables.RemoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
														CommandParameter="{Binding}">
													<materialIcons:MaterialIcon Kind="Close" Width="13" Height="13" />
												</Button>
											</Grid>
										</Border>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>

							<TextBlock Classes="sectionLabel" Text="CONSTANTS" />
							<TextBlock Classes="emptyState" IsVisible="{Binding Constants.IsEmpty}"
									   Text="None yet — add one below." />
							<ItemsControl ItemsSource="{Binding Constants.Items}">
								<ItemsControl.ItemTemplate>
									<DataTemplate x:DataType="overlay:ConstantItem">
										<Border Classes="paletteRow">
											<Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
												<TextBlock Grid.Column="0" Classes="mono" Text="{Binding Name}" />
												<TextBlock Grid.Column="1" Classes="desc"
														   IsVisible="{Binding HasDescription}"
														   Text="{Binding Description}" />
												<controls:QuantityView Grid.Column="2" Value="{Binding Value}"
																	   VerticalAlignment="Center" />
												<Button Grid.Column="3" Classes="remove"
														Command="{Binding ((vm:CommandPaletteViewModel)DataContext).Constants.RemoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
														CommandParameter="{Binding}">
													<materialIcons:MaterialIcon Kind="Close" Width="13" Height="13" />
												</Button>
											</Grid>
										</Border>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
						</StackPanel>
					</ScrollViewer>

					<!-- ============================= UNITS ============================= -->
					<Grid IsVisible="{Binding IsUnits}" RowDefinitions="Auto,*">
						<!-- Segmented Input / Output tabs (fixed above the list), with the active tab's caption
						     to their right. Kept out of the scroll region so the list below can virtualize. -->
						<Grid Grid.Row="0" ColumnDefinitions="Auto,*"
							  Margin="{DynamicResource AddRowPadding}">
							<Border Grid.Column="0" HorizontalAlignment="Left"
									Background="{DynamicResource BgBrush}"
									CornerRadius="7" Padding="3">
								<StackPanel Orientation="Horizontal" Spacing="3">
									<Button Classes="tab" Classes.active="{Binding IsInputTab}"
											Command="{Binding ShowInputUnitsCommand}" Content="Input units" />
									<Button Classes="tab" Classes.active="{Binding IsOutputTab}"
											Command="{Binding ShowOutputUnitsCommand}" Content="Output units" />
								</StackPanel>
							</Border>
							<Panel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
								<TextBlock Classes="rowCaption" Margin="0" VerticalAlignment="Center"
										   IsVisible="{Binding IsInputTab}" Text="resolve to base SI" />
								<TextBlock Classes="rowCaption" Margin="0" VerticalAlignment="Center"
										   IsVisible="{Binding IsOutputTab}" Text="candidates the app auto-picks from" />
							</Panel>
						</Grid>

						<!-- The two tab bodies share the row; each is its own bounded scroll region. -->
						<Panel Grid.Row="1">

							<!-- Input units. -->
							<Panel IsVisible="{Binding IsInputTab}">
								<ScrollViewer HorizontalScrollBarVisibility="Disabled">
									<ItemsControl ItemsSource="{Binding InputUnits.Items}"
												  Margin="{DynamicResource AddRowPadding}">
										<ItemsControl.ItemsPanel>
											<ItemsPanelTemplate>
												<VirtualizingStackPanel />
											</ItemsPanelTemplate>
										</ItemsControl.ItemsPanel>
										<ItemsControl.ItemTemplate>
											<DataTemplate x:DataType="overlay:InputUnitItem">
												<Border Classes="paletteRow">
													<Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
														<StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6"
																	VerticalAlignment="Center">
															<TextBlock Classes="mono" FontWeight="Medium"
																	   Foreground="{DynamicResource UnitHueBrush}"
																	   Text="{Binding Symbol}" />
															<TextBlock Classes="mono" Foreground="{DynamicResource FaintBrush}"
																	   Text="=" />
															<controls:QuantityView Value="{Binding Definition}"
																				   VerticalAlignment="Center" />
														</StackPanel>
														<Button Grid.Column="1" Classes="remove" IsVisible="{Binding CanRemove}"
																Command="{Binding ((vm:CommandPaletteViewModel)DataContext).InputUnits.RemoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
																CommandParameter="{Binding}">
															<materialIcons:MaterialIcon Kind="Close" Width="13" Height="13" />
														</Button>
													</Grid>
												</Border>
											</DataTemplate>
										</ItemsControl.ItemTemplate>
									</ItemsControl>
								</ScrollViewer>
								<TextBlock Classes="emptyState" Margin="{DynamicResource AddRowPadding}"
										   IsVisible="{Binding InputUnits.IsEmpty}" Text="No input units." />
							</Panel>

							<!-- Output units: one flat, virtualized list — a section-header row per physical
							     quantity followed by that group's unit rows (matched to templates by type). -->
							<Panel IsVisible="{Binding IsOutputTab}">
								<ScrollViewer HorizontalScrollBarVisibility="Disabled">
									<ItemsControl x:Name="OutputUnitsList"
												  ItemsSource="{Binding OutputUnits.Rows}"
												  Margin="{DynamicResource AddRowPadding}">
										<ItemsControl.ItemsPanel>
											<ItemsPanelTemplate>
												<VirtualizingStackPanel />
											</ItemsPanelTemplate>
										</ItemsControl.ItemsPanel>
										<ItemsControl.DataTemplates>
											<DataTemplate DataType="overlay:OutputHeaderRow">
												<Panel Margin="0,14,0,7">

													<!-- DISPLAY MODE -->
													<Grid IsVisible="{Binding !IsEditing}"
														  ColumnDefinitions="Auto,Auto" ColumnSpacing="7">
														<TextBlock Grid.Column="0" Classes="sectionLabel" Margin="0"
																   VerticalAlignment="Center" Text="{Binding Label}" />
														<Button Grid.Column="1" Classes="headerIcon"
																ToolTip.Tip="Rename category"
																Command="{Binding ((vm:CommandPaletteViewModel)DataContext).OutputUnits.BeginRenameCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
																CommandParameter="{Binding}">
															<materialIcons:MaterialIcon Kind="Pencil" Width="13" Height="13" />
														</Button>
													</Grid>

													<!-- EDIT MODE -->
													<Grid IsVisible="{Binding IsEditing}"
														  ColumnDefinitions="*,Auto" ColumnSpacing="7">
														<TextBox Grid.Column="0" Classes="addField"
																 Loaded="OnRenameFieldLoaded"
																 Text="{Binding ((vm:CommandPaletteViewModel)DataContext).OutputUnits.CategoryDraft, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}">
															<TextBox.KeyBindings>
																<KeyBinding Gesture="Enter"
																			Command="{Binding ((vm:CommandPaletteViewModel)DataContext).OutputUnits.CommitRenameCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
																<KeyBinding Gesture="Escape"
																			Command="{Binding ((vm:CommandPaletteViewModel)DataContext).OutputUnits.CancelRenameCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
															</TextBox.KeyBindings>
														</TextBox>
														<Button Grid.Column="1" Classes="add" Content="Save"
																Command="{Binding ((vm:CommandPaletteViewModel)DataContext).OutputUnits.CommitRenameCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
													</Grid>
												</Panel>
											</DataTemplate>
											<DataTemplate DataType="overlay:OutputUnitItem">
												<Border Classes="paletteRow">
													<Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
														<StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6"
																	VerticalAlignment="Center">
															<controls:UnitView Value="{Binding Key.OutputUnit}"
																			   VerticalAlignment="Center" />
															<TextBlock Classes="mono" Foreground="{DynamicResource FaintBrush}"
																	   Text="=" />
															<controls:QuantityView Value="{Binding Definition}"
																				   VerticalAlignment="Center" />
														</StackPanel>
														<Button Grid.Column="1" Classes="remove" IsVisible="{Binding CanRemove}"
																Command="{Binding ((vm:CommandPaletteViewModel)DataContext).OutputUnits.RemoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
																CommandParameter="{Binding}">
															<materialIcons:MaterialIcon Kind="Close" Width="13" Height="13" />
														</Button>
													</Grid>
												</Border>
											</DataTemplate>
										</ItemsControl.DataTemplates>
									</ItemsControl>
								</ScrollViewer>
								<TextBlock Classes="emptyState" Margin="{DynamicResource AddRowPadding}"
										   IsVisible="{Binding OutputUnits.IsEmpty}" Text="No output units." />
							</Panel>
						</Panel>
					</Grid>

					<!-- =========================== FUNCTIONS =========================== -->
					<ScrollViewer IsVisible="{Binding IsFunctions}" HorizontalScrollBarVisibility="Disabled">
						<StackPanel Margin="{DynamicResource AddRowPadding}">
							<TextBlock Classes="sectionLabel" Text="YOUR FUNCTIONS" />
							<TextBlock Classes="emptyState" IsVisible="{Binding Functions.IsEmpty}"
									   Text="None yet — define one below, or on a line like `f(x) = x^2 + 1`." />
							<ItemsControl ItemsSource="{Binding Functions.Items}">
								<ItemsControl.ItemTemplate>
									<DataTemplate x:DataType="overlay:FunctionItem">
										<Border Classes="paletteRow">
											<Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
												<StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
															VerticalAlignment="Center">
													<TextBlock Classes="mono" FontWeight="Medium" Text="{Binding Signature}" />
													<TextBlock Classes="mono" Foreground="{DynamicResource FaintBrush}"
															   IsVisible="{Binding HasBody}"
															   Text="{Binding Body, StringFormat='= {0}'}" />
													<Border Classes="fromSheet" IsVisible="{Binding FromSheet}">
														<TextBlock Text="from sheet" />
													</Border>
												</StackPanel>
												<Button Grid.Column="1" Classes="remove" IsVisible="{Binding CanRemove}"
														Command="{Binding ((vm:CommandPaletteViewModel)DataContext).Functions.RemoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
														CommandParameter="{Binding}">
													<materialIcons:MaterialIcon Kind="Close" Width="13" Height="13" />
												</Button>
											</Grid>
										</Border>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>

							<TextBlock Classes="sectionLabel" Text="BUILT-IN — ALWAYS AVAILABLE" />
							<ItemsControl ItemsSource="{Binding BuiltInFunctions.Items}">
								<ItemsControl.ItemTemplate>
									<DataTemplate x:DataType="overlay:BuiltInFunctionItem">
										<Border Classes="paletteRow">
											<Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
												<TextBlock Grid.Column="0" Classes="mono" Text="{Binding Signature}" />
												<TextBlock Grid.Column="1" Classes="desc" Text="{Binding Description}" />
											</Grid>
										</Border>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
						</StackPanel>
					</ScrollViewer>
				</Panel>

				<!-- ============================ FOOTER (add-row) ============================ -->
				<!-- One form per section/tab. Each inner Grid rebinds its DataContext to the owning panel
				     so its fields, Add command and error bind directly; Enter in either field submits. -->
				<Border Grid.Row="2" Classes="addRow">
					<Panel>

						<!-- New constant: name + value + optional description. -->
						<StackPanel IsVisible="{Binding IsVariables}">
							<Grid DataContext="{Binding Constants}" x:DataType="overlay:ConstantsPanelViewModel"
								  ColumnDefinitions="Auto,*,Auto,*,*,Auto" ColumnSpacing="9">
								<TextBlock Grid.Column="0" Classes="addLabel" Text="＋ New constant" />
								<TextBox Grid.Column="1" Classes="addField" Text="{Binding NewName}" PlaceholderText="name">
									<TextBox.KeyBindings>
										<KeyBinding Gesture="Enter" Command="{Binding AddCommand}" />
									</TextBox.KeyBindings>
								</TextBox>
								<TextBlock Grid.Column="2" Classes="addSeparator" Text="=" />
								<TextBox Grid.Column="3" Classes="addField" Text="{Binding NewValue}" PlaceholderText="value, e.g. 9.81 m/s^2">
									<TextBox.KeyBindings>
										<KeyBinding Gesture="Enter" Command="{Binding AddCommand}" />
									</TextBox.KeyBindings>
								</TextBox>
								<TextBox Grid.Column="4" Classes="addField" Text="{Binding NewDescription}" PlaceholderText="description (optional)">
									<TextBox.KeyBindings>
										<KeyBinding Gesture="Enter" Command="{Binding AddCommand}" />
									</TextBox.KeyBindings>
								</TextBox>
								<Button Grid.Column="5" Classes="add" Content="Add" Command="{Binding AddCommand}" />
							</Grid>
							<TextBlock DataContext="{Binding Constants}" x:DataType="overlay:ConstantsPanelViewModel"
									   Classes="addError" IsVisible="{Binding HasError}" Text="{Binding ErrorMessage}" />
						</StackPanel>

						<!-- New units: depends on the active tab. -->
						<Panel IsVisible="{Binding IsUnits}">
							<!-- New input unit: symbol + base-unit definition. -->
							<StackPanel IsVisible="{Binding IsInputTab}">
								<Grid DataContext="{Binding InputUnits}" x:DataType="overlay:InputUnitsPanelViewModel"
									  ColumnDefinitions="Auto,*,Auto,*,Auto" ColumnSpacing="9">
									<TextBlock Grid.Column="0" Classes="addLabel" Text="＋ New input unit" />
									<TextBox Grid.Column="1" Classes="addField" Text="{Binding NewSymbol}" PlaceholderText="symbol">
										<TextBox.KeyBindings>
											<KeyBinding Gesture="Enter" Command="{Binding AddCommand}" />
										</TextBox.KeyBindings>
									</TextBox>
									<TextBlock Grid.Column="2" Classes="addSeparator" Text="=" />
									<TextBox Grid.Column="3" Classes="addField" Text="{Binding NewDefinition}" PlaceholderText="value in base units — blank for a new base unit">
										<TextBox.KeyBindings>
											<KeyBinding Gesture="Enter" Command="{Binding AddCommand}" />
										</TextBox.KeyBindings>
									</TextBox>
									<Button Grid.Column="4" Classes="add" Content="Add" Command="{Binding AddCommand}" />
								</Grid>
								<TextBlock DataContext="{Binding InputUnits}" x:DataType="overlay:InputUnitsPanelViewModel"
										   Classes="addError" IsVisible="{Binding HasError}" Text="{Binding ErrorMessage}" />
							</StackPanel>

							<!-- New output unit: unit + base-unit definition. -->
							<StackPanel IsVisible="{Binding IsOutputTab}">
								<Grid DataContext="{Binding OutputUnits}" x:DataType="overlay:OutputUnitsPanelViewModel"
									  ColumnDefinitions="Auto,*,Auto,*,Auto" ColumnSpacing="9">
									<TextBlock Grid.Column="0" Classes="addLabel" Text="＋ New output unit" />
									<TextBox Grid.Column="1" Classes="addField" Text="{Binding NewUnit}" PlaceholderText="unit">
										<TextBox.KeyBindings>
											<KeyBinding Gesture="Enter" Command="{Binding AddCommand}" />
										</TextBox.KeyBindings>
									</TextBox>
									<TextBlock Grid.Column="2" Classes="addSeparator" Text="=" />
									<TextBox Grid.Column="3" Classes="addField" Text="{Binding NewDefinition}" PlaceholderText="expression">
										<TextBox.KeyBindings>
											<KeyBinding Gesture="Enter" Command="{Binding AddCommand}" />
										</TextBox.KeyBindings>
									</TextBox>
									<Button Grid.Column="4" Classes="add" Content="Add" Command="{Binding AddCommand}" />
								</Grid>
								<TextBlock DataContext="{Binding OutputUnits}" x:DataType="overlay:OutputUnitsPanelViewModel"
										   Classes="addError" IsVisible="{Binding HasError}" Text="{Binding ErrorMessage}" />
							</StackPanel>
						</Panel>

						<!-- New function: signature + body. -->
						<StackPanel IsVisible="{Binding IsFunctions}">
							<Grid DataContext="{Binding Functions}" x:DataType="overlay:FunctionsPanelViewModel"
								  ColumnDefinitions="Auto,*,Auto,*,Auto" ColumnSpacing="9">
								<TextBlock Grid.Column="0" Classes="addLabel" Text="＋ New function" />
								<TextBox Grid.Column="1" Classes="addField" Text="{Binding NewSignature}" PlaceholderText="f(x)">
									<TextBox.KeyBindings>
										<KeyBinding Gesture="Enter" Command="{Binding AddCommand}" />
									</TextBox.KeyBindings>
								</TextBox>
								<TextBlock Grid.Column="2" Classes="addSeparator" Text="=" />
								<TextBox Grid.Column="3" Classes="addField" Text="{Binding NewBody}" PlaceholderText="body, e.g. x^2 + 1">
									<TextBox.KeyBindings>
										<KeyBinding Gesture="Enter" Command="{Binding AddCommand}" />
									</TextBox.KeyBindings>
								</TextBox>
								<Button Grid.Column="4" Classes="add" Content="Add" Command="{Binding AddCommand}" />
							</Grid>
							<TextBlock DataContext="{Binding Functions}" x:DataType="overlay:FunctionsPanelViewModel"
									   Classes="addError" IsVisible="{Binding HasError}" Text="{Binding ErrorMessage}" />
						</StackPanel>
					</Panel>
				</Border>
			</Grid>
			</Border>
		</Grid>
	</Border>
</UserControl>
