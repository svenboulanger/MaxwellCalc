<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:MaxwellCalc.Notebook.ViewModels"
        mc:Ignorable="d" d:DesignWidth="820" d:DesignHeight="620"
        Width="820" Height="620"
        x:Class="MaxwellCalc.Notebook.Views.ShellWindow"
        x:DataType="vm:ShellViewModel"
        ExtendClientAreaToDecorationsHint="True"
        Title="MaxwellCalc">
	<!-- Step 1 scaffold: intentionally blank. The title bar, sheet, access bar and overlay
	     are built in Steps 3+. This placeholder only confirms DI + data binding are wired. -->
	<Panel>
		<TextBlock HorizontalAlignment="Center"
				   VerticalAlignment="Center"
				   Opacity="0.5"
				   Text="{Binding WorkspaceName, StringFormat='MaxwellCalc — {0}'}" />
	</Panel>
</Window>
