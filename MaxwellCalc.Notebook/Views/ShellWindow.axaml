<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:MaxwellCalc.Notebook.ViewModels"
        xmlns:views="using:MaxwellCalc.Notebook.Views"
        xmlns:controls="using:MaxwellCalc.Notebook.Controls"
        xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        mc:Ignorable="d" d:DesignWidth="820" d:DesignHeight="620"
        Width="820" Height="620" MinWidth="560" MinHeight="360"
        x:Class="MaxwellCalc.Notebook.Views.ShellWindow"
        x:DataType="vm:ShellViewModel"
        ExtendClientAreaToDecorationsHint="True"
        WindowDecorations="BorderOnly"
        Background="{DynamicResource BgBrush}"
        Closing="OnClosing"
        Icon="/Assets/maxwell-icon.png"
        Title="MaxwellCalc">

	<Window.Styles>
		<!-- Custom window caption buttons (min / max-restore / close) and the theme toggle.
		     Flush to the top-right, 46x44, transparent with a subtle hover; close hovers red. -->
		<Style Selector="Button.caption">
			<Setter Property="Width" Value="46" />
			<Setter Property="Height" Value="44" />
			<Setter Property="Padding" Value="0" />
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="CornerRadius" Value="0" />
			<Setter Property="VerticalAlignment" Value="Stretch" />
			<Setter Property="Foreground" Value="{DynamicResource MutBrush}" />
		</Style>
		<Style Selector="Button.caption /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="CornerRadius" Value="0" />
		</Style>
		<Style Selector="Button.caption:pointerover /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="{DynamicResource LineBrush}" />
		</Style>
		<Style Selector="Button.caption:pointerover">
			<Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
		</Style>
		<Style Selector="Button.caption.close:pointerover /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="{DynamicResource ErrBrush}" />
		</Style>
		<Style Selector="Button.caption.close:pointerover">
			<Setter Property="Foreground" Value="White" />
		</Style>

		<!-- Settings flyout: section caption + unit-hue swatch buttons. -->
		<Style Selector="TextBlock.settingsLabel">
			<Setter Property="FontFamily" Value="{DynamicResource UiFontFamily}" />
			<Setter Property="FontSize" Value="10.5" />
			<Setter Property="FontWeight" Value="SemiBold" />
			<Setter Property="Foreground" Value="{DynamicResource FaintBrush}" />
		</Style>
		<!-- Chrome-less button wrapping a color swatch (kept transparent in every state). -->
		<Style Selector="Button.hueBtn">
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="Padding" Value="0" />
			<Setter Property="CornerRadius" Value="6" />
			<Setter Property="Cursor" Value="Hand" />
		</Style>
		<Style Selector="Button.hueBtn /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="Transparent" />
		</Style>
		<Style Selector="Button.hueBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="Transparent" />
		</Style>
		<Style Selector="Button.hueBtn:pressed /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="Transparent" />
		</Style>
		<!-- The swatch itself: a rounded color chip with a ring that darkens when selected. -->
		<Style Selector="Border.swatch">
			<Setter Property="Width" Value="34" />
			<Setter Property="Height" Value="24" />
			<Setter Property="CornerRadius" Value="6" />
			<Setter Property="BorderThickness" Value="2" />
			<Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
		</Style>
		<Style Selector="Border.swatch.active">
			<Setter Property="BorderBrush" Value="{DynamicResource InkBrush}" />
		</Style>

		<!-- ===================== Workspace switcher flyout ===================== -->
		<!-- The name button: chrome-less, fills the row, ink label, subtle hover. -->
		<Style Selector="Button.wsName">
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="CornerRadius" Value="6" />
			<Setter Property="Padding" Value="7,5" />
			<Setter Property="HorizontalAlignment" Value="Stretch" />
			<Setter Property="HorizontalContentAlignment" Value="Left" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="FontFamily" Value="{DynamicResource UiFontFamily}" />
			<Setter Property="FontSize" Value="12.5" />
			<Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
		</Style>
		<Style Selector="Button.wsName:pointerover /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="{DynamicResource LineBrush}" />
		</Style>
		<!-- Small square icon button for the per-row gear / pencil / delete affordances. -->
		<Style Selector="Button.wsIcon">
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="CornerRadius" Value="5" />
			<Setter Property="Padding" Value="5" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="Foreground" Value="{DynamicResource MutBrush}" />
			<Setter Property="VerticalAlignment" Value="Center" />
		</Style>
		<Style Selector="Button.wsIcon:pointerover /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="{DynamicResource LineBrush}" />
		</Style>
		<Style Selector="Button.wsIcon:pointerover">
			<Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
		</Style>
		<Style Selector="Button.wsIcon.delete:pointerover">
			<Setter Property="Foreground" Value="{DynamicResource ErrBrush}" />
		</Style>
		<!-- Per-row domain badge: a small uppercase mono pill (Double / Complex). -->
		<Style Selector="Border.wsBadge">
			<Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
			<Setter Property="BorderThickness" Value="1" />
			<Setter Property="CornerRadius" Value="5" />
			<Setter Property="Padding" Value="5,2" />
			<Setter Property="VerticalAlignment" Value="Center" />
			<Setter Property="Margin" Value="4,0" />
		</Style>
		<Style Selector="Border.wsBadge > TextBlock">
			<Setter Property="FontFamily" Value="{DynamicResource MonoFontFamily}" />
			<Setter Property="FontSize" Value="10" />
			<Setter Property="Foreground" Value="{DynamicResource FaintBrush}" />
		</Style>
		<!-- "+ New workspace" row: accent text, chrome-less. -->
		<Style Selector="Button.wsNew">
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="CornerRadius" Value="6" />
			<Setter Property="Padding" Value="7,6" />
			<Setter Property="HorizontalAlignment" Value="Stretch" />
			<Setter Property="HorizontalContentAlignment" Value="Left" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
		</Style>
		<Style Selector="Button.wsNew:pointerover /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="{DynamicResource LineBrush}" />
		</Style>
	</Window.Styles>

	<!-- Global shortcuts: every access-bar chip has its own window-level hotkey, opening the same overlay
	     (or running the same action) as clicking it. The line editor only handles unmodified
	     Enter/Backspace/arrows (it ignores any keypress carrying a modifier), so these all bubble up to
	     here even while a sheet line has focus. Esc closes whichever overlay is open (a no-op otherwise).
	     Each binds both the Windows/Linux (Ctrl) and macOS (Meta / ⌘) gesture. -->
	<Window.KeyBindings>
		<!-- ⌘J / Ctrl+J opens the command palette on the Variables section. -->
		<KeyBinding Gesture="Ctrl+J" Command="{Binding CommandPalette.OpenVariablesCommand}" />
		<KeyBinding Gesture="Meta+J" Command="{Binding CommandPalette.OpenVariablesCommand}" />
		<!-- ⌘U / Ctrl+U opens the command palette on the Units section (Input tab). -->
		<KeyBinding Gesture="Ctrl+U" Command="{Binding CommandPalette.OpenUnitsCommand}" />
		<KeyBinding Gesture="Meta+U" Command="{Binding CommandPalette.OpenUnitsCommand}" />
		<!-- ⌘F / Ctrl+F opens the command palette on the Functions section. -->
		<KeyBinding Gesture="Ctrl+F" Command="{Binding CommandPalette.OpenFunctionsCommand}" />
		<KeyBinding Gesture="Meta+F" Command="{Binding CommandPalette.OpenFunctionsCommand}" />
		<!-- ⌘O / Ctrl+O opens the Saved Sheets palette. -->
		<KeyBinding Gesture="Ctrl+O" Command="{Binding SavedSheets.OpenCommand}" />
		<KeyBinding Gesture="Meta+O" Command="{Binding SavedSheets.OpenCommand}" />
		<!-- ⌘N / Ctrl+N clears the current sheet back to one empty, focused line (no confirmation). It
		     closes any open overlay first and fires regardless of which line editor has focus. -->
		<KeyBinding Gesture="Ctrl+N" Command="{Binding ClearSheetCommand}" />
		<KeyBinding Gesture="Meta+N" Command="{Binding ClearSheetCommand}" />
		<!-- Esc first tries to close the new-workspace dialog, then the workspace-settings dialog, then the
		     Saved Sheets palette (each guarded by its CanExecute, so it only fires when that overlay is
		     open — the top-most overlay closes first); when none of those are open the command palette's
		     (ungated) Esc handler runs. -->
		<KeyBinding Gesture="Escape" Command="{Binding Settings.CloseNewWorkspaceCommand}" />
		<KeyBinding Gesture="Escape" Command="{Binding Settings.CloseWorkspaceSettingsCommand}" />
		<KeyBinding Gesture="Escape" Command="{Binding SavedSheets.CloseCommand}" />
		<KeyBinding Gesture="Escape" Command="{Binding CommandPalette.CloseCommand}" />
	</Window.KeyBindings>

	<!-- Three-region single-window shell (title bar / sheet / access bar) with the command-palette
	     overlay layered on top (Step 8). The overlay's scrim spans the whole window; when closed it is
	     collapsed and transparent to hit-testing so the shell underneath stays interactive. -->
	<Panel>
	<Grid RowDefinitions="Auto,*,Auto">

		<!-- ============================ TITLE BAR ============================ -->
		<Border Grid.Row="0"
				Name="TitleBar"
				Height="{DynamicResource TitleBarHeight}"
				Background="{DynamicResource BarBrush}"
				BorderBrush="{DynamicResource LineBrush}"
				BorderThickness="0,0,0,1"
				PointerPressed="OnTitleBarPointerPressed">
			<Grid ColumnDefinitions="Auto,*,Auto" Margin="14,0,0,0">

				<!-- Left cluster: app mark + name + workspace caption (gap 10). -->
				<StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10"
							VerticalAlignment="Center">
					<!-- App mark: accent tile + white hollow nabla and amber unit dot (∇·),
					     matching the divergence-operator app icon. -->
					<Panel Width="15" Height="15">
						<Border CornerRadius="{DynamicResource AppMarkCornerRadius}"
								Background="{DynamicResource AccentBrush}" />
						<!-- Dot enlarged vs the icon's true proportion so it stays legible
						     at title-bar size; group kept centered as a unit. -->
						<Canvas>
							<Path Data="M 3.45,4.9 L 7.85,4.9 L 5.65,10.4 Z"
								  Stroke="White" StrokeThickness="0.9" StrokeJoin="Round" />
							<Ellipse Canvas.Left="9.8" Canvas.Top="6.4"
									 Width="2.2" Height="2.2"
									 Fill="{DynamicResource UnitHueBrush}" />
						</Canvas>
					</Panel>
					<TextBlock Text="MaxwellCalc"
							   FontFamily="{DynamicResource UiFontFamily}"
							   FontSize="12.5" FontWeight="SemiBold"
							   Foreground="{DynamicResource InkBrush}"
							   VerticalAlignment="Center" />
					<TextBlock Text="{Binding WorkspaceName, StringFormat='— {0}'}"
							   FontFamily="{DynamicResource UiFontFamily}"
							   FontSize="11"
							   Foreground="{DynamicResource FaintBrush}"
							   VerticalAlignment="Center" />
				</StackPanel>

				<!-- Right cluster: theme toggle + custom window caption buttons. We use
				     SystemDecorations="BorderOnly" (native resize border + shadow, no native
				     title/buttons), so the min/max/close buttons are drawn and wired here. -->
				<StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Stretch">
					<!-- Settings: unit-hue swatches + the auto-caption toggle. -->
					<Button Classes="caption" ToolTip.Tip="Settings">
						<materialIcons:MaterialIcon Kind="Cog" Width="16" Height="16" />
						<Button.Flyout>
							<Flyout Placement="BottomEdgeAlignedRight" Closed="OnTitleBarFlyoutClosed">
								<StackPanel Width="230" Spacing="12" Margin="4,6">
									<TextBlock Classes="settingsLabel" Text="UNIT COLOR" />
									<StackPanel Orientation="Horizontal" Spacing="10">
										<Button Classes="hueBtn"
												Command="{Binding Settings.SetUnitHueCommand}"
												CommandParameter="{x:Static vm:UnitHue.Amber}"
												ToolTip.Tip="Amber">
											<Border Classes="swatch" Classes.active="{Binding Settings.IsAmber}"
													Background="{DynamicResource UnitHueAmberBrush}" />
										</Button>
										<Button Classes="hueBtn"
												Command="{Binding Settings.SetUnitHueCommand}"
												CommandParameter="{x:Static vm:UnitHue.Green}"
												ToolTip.Tip="Green">
											<Border Classes="swatch" Classes.active="{Binding Settings.IsGreen}"
													Background="{DynamicResource UnitHueGreenBrush}" />
										</Button>
										<Button Classes="hueBtn"
												Command="{Binding Settings.SetUnitHueCommand}"
												CommandParameter="{x:Static vm:UnitHue.Violet}"
												ToolTip.Tip="Violet">
											<Border Classes="swatch" Classes.active="{Binding Settings.IsViolet}"
													Background="{DynamicResource UnitHueVioletBrush}" />
										</Button>
									</StackPanel>
									<CheckBox IsChecked="{Binding Settings.AutoCaptionEnabled}"
											  FontFamily="{DynamicResource UiFontFamily}"
											  FontSize="12"
											  Foreground="{DynamicResource InkBrush}"
											  Content="Auto-select output unit caption" />
								</StackPanel>
							</Flyout>
						</Button.Flyout>
					</Button>
					<Button Command="{Binding Settings.ToggleThemeCommand}"
							Classes="caption"
							Margin="0,0,6,0"
							ToolTip.Tip="Toggle light / dark">
						<materialIcons:MaterialIcon Kind="{Binding Settings.ThemeToggleIcon}" Width="16" Height="16" />
					</Button>
					<Button Classes="caption" Click="OnMinimize" ToolTip.Tip="Minimize">
						<materialIcons:MaterialIcon Kind="WindowMinimize" Width="15" Height="15" />
					</Button>
					<Button Classes="caption" Click="OnMaximizeRestore" ToolTip.Tip="Maximize">
						<materialIcons:MaterialIcon Name="MaxRestoreIcon" Kind="WindowMaximize"
													Width="14" Height="14" />
					</Button>
					<Button Classes="caption close" Click="OnClose" ToolTip.Tip="Close">
						<materialIcons:MaterialIcon Kind="WindowClose" Width="15" Height="15" />
					</Button>
				</StackPanel>
			</Grid>
		</Border>

		<!-- ============================ SHEET REGION ============================ -->
		<!-- The live notebook sheet. SheetView renders one editable row per line with its result
		     gutter (Step 5); resolved via the ViewLocator from ShellViewModel.Sheet. -->
		<ScrollViewer Grid.Row="1" Background="{DynamicResource SurfBrush}"
					  HorizontalScrollBarVisibility="Disabled">
			<ContentControl Content="{Binding Sheet}" />
		</ScrollViewer>

		<!-- ============================ ACCESS BAR ============================ -->
		<Border Grid.Row="2"
				Background="{DynamicResource BarFooterBrush}"
				BorderBrush="{DynamicResource LineBrush}"
				BorderThickness="0,1,0,0"
				Padding="{DynamicResource AccessBarPadding}">
			<!-- Physics ▾ button + divider + chips (gap 9). All left-aligned: the static key-hint pills
			     that used to sit at the far right are gone — every chip now carries its own hotkey and a
			     descriptive tooltip ending in that hotkey. -->
			<StackPanel Orientation="Horizontal" Spacing="9"
						VerticalAlignment="Center">
					<Button Name="WorkspaceSwitcherButton"
							Background="{DynamicResource AccentBrush}"
							Foreground="White"
							BorderThickness="0"
							CornerRadius="{DynamicResource ButtonCornerRadius}"
							Padding="11,6"
							ToolTip.Tip="Switch workspace">
						<StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
							<TextBlock Text="{Binding WorkspaceName}"
									   FontFamily="{DynamicResource UiFontFamily}"
									   FontSize="12" FontWeight="SemiBold"
									   VerticalAlignment="Center" />
							<materialIcons:MaterialIcon Kind="MenuDown" Width="15" Height="15"
														VerticalAlignment="Center" />
						</StackPanel>
						<!-- Workspace switcher: full CRUD. Each row binds its own per-entry commands
						     (Select / OpenSettings / Rename / Remove), so no binding crosses the flyout
						     popup boundary back to the shell. Select and the gear also close the flyout
						     (code-behind); rename/delete keep it open so the list stays visible. -->
						<Button.Flyout>
							<Flyout Placement="TopEdgeAlignedLeft" Closed="OnTitleBarFlyoutClosed">
								<StackPanel Width="252" Spacing="1" Margin="4,6">
									<TextBlock Classes="settingsLabel" Text="WORKSPACES" Margin="7,2,0,6" />
									<ItemsControl ItemsSource="{Binding Settings.Workspaces}">
										<ItemsControl.ItemTemplate>
											<DataTemplate x:DataType="vm:WorkspaceEntry">
												<Grid ColumnDefinitions="18,*,Auto,Auto,Auto">
													<!-- Active check mark. -->
													<materialIcons:MaterialIcon Grid.Column="0" Kind="Check"
																				Width="14" Height="14"
																				IsVisible="{Binding IsSelected}"
																				Foreground="{DynamicResource AccentBrush}"
																				VerticalAlignment="Center" />

													<!-- Name (select). -->
													<Button Grid.Column="1" Classes="wsName"
															Content="{Binding Name}"
															Command="{Binding SelectCommand}"
															Click="OnWorkspaceRowActivated" />

													<!-- Domain badge (Double / Complex). -->
													<Border Grid.Column="2" Classes="wsBadge"
															ToolTip.Tip="{Binding DomainTooltip}">
														<TextBlock Text="{Binding DomainBadge}" />
													</Border>

													<Button Grid.Column="3" Classes="wsIcon"
															Command="{Binding OpenSettingsCommand}"
															Click="OnWorkspaceRowActivated"
															ToolTip.Tip="Workspace settings">
														<materialIcons:MaterialIcon Kind="Cog" Width="14" Height="14" />
													</Button>
													<Button Grid.Column="4" Classes="wsIcon delete"
															Command="{Binding RemoveCommand}"
															ToolTip.Tip="Delete workspace">
														<materialIcons:MaterialIcon Kind="Close" Width="14" Height="14" />
													</Button>
												</Grid>
											</DataTemplate>
										</ItemsControl.ItemTemplate>
									</ItemsControl>

									<Border Height="1" Background="{DynamicResource LineBrush}" Margin="0,5" />

									<Button Classes="wsNew" Command="{Binding Settings.OpenNewWorkspaceCommand}"
											Click="OnWorkspaceRowActivated">
										<StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
											<materialIcons:MaterialIcon Kind="Plus" Width="15" Height="15"
																		VerticalAlignment="Center" />
											<TextBlock Text="New workspace"
													   FontFamily="{DynamicResource UiFontFamily}"
													   FontSize="12.5" FontWeight="Medium"
													   VerticalAlignment="Center" />
										</StackPanel>
									</Button>
								</StackPanel>
							</Flyout>
						</Button.Flyout>
					</Button>

					<Border Width="1" Height="20" Background="{DynamicResource LineBrush}"
							VerticalAlignment="Center" Margin="3,0" />

					<controls:Chip Glyph="x" GlyphFontStyle="Italic"
								   GlyphForeground="{DynamicResource AccentBrush}"
								   Label="Variables" Count="{Binding CommandPalette.Variables.Count}"
								   Command="{Binding CommandPalette.OpenVariablesCommand}"
								   ToolTip.Tip="{Binding VariablesTooltip}" />
					<controls:Chip Glyph="m"
								   GlyphForeground="{DynamicResource UnitHueBrush}"
								   Label="Units" Count="{Binding CommandPalette.InputUnits.Count}"
								   Command="{Binding CommandPalette.OpenUnitsCommand}"
								   ToolTip.Tip="{Binding UnitsTooltip}" />
					<controls:Chip Glyph="f" GlyphFontStyle="Italic"
								   GlyphForeground="{DynamicResource AccentBrush}"
								   Label="Functions" Count="{Binding CommandPalette.Functions.Count}"
								   Command="{Binding CommandPalette.OpenFunctionsCommand}"
								   ToolTip.Tip="{Binding FunctionsTooltip}" />

					<!-- Thin divider before the Saved Sheets chip: this is a separate library, not part of
					     the workspace's variables / units / functions. -->
					<Border Width="1" Height="20" Background="{DynamicResource LineBrush}"
							VerticalAlignment="Center" Margin="2,0" />

					<controls:Chip Glyph="▤"
								   GlyphForeground="{DynamicResource AccentBrush}"
								   Label="Sheets" Count="{Binding SavedSheets.CountLabel}"
								   Command="{Binding SavedSheets.OpenCommand}"
								   ToolTip.Tip="{Binding SheetsTooltip}" />

					<!-- Clear sheet (⌘N / Ctrl+N): wipes the sheet to one empty focused line. Styled as a
					     neutral chip, not a destructive button — the action is cheap and instantly
					     recoverable. The ⌦ (delete-forward) glyph renders in the accent color. -->
					<controls:Chip Glyph="⌦"
								   GlyphForeground="{DynamicResource AccentBrush}"
								   Label="Clear sheet"
								   Command="{Binding ClearSheetCommand}"
								   ToolTip.Tip="{Binding ClearSheetTooltip}" />
			</StackPanel>
		</Border>
	</Grid>

		<!-- Command-palette overlay, resolved to CommandPaletteView via the ViewLocator. It manages its
		     own visibility (scrim IsVisible = PaletteOpen), so it stays here spanning the whole window. -->
		<ContentControl Content="{Binding CommandPalette}" />

		<!-- Saved Sheets overlay (⌘O), resolved to SavedSheetsView. Layered above the command palette so
		     that when both are open the top-most (this one) closes first on Esc / scrim click. -->
		<ContentControl Content="{Binding SavedSheets}" />

		<!-- Workspace-settings dialog (Step 12). Bound directly to the SettingsViewModel; manages its own
		     visibility (scrim IsVisible = WorkspaceSettingsOpen) and layers above the palette. -->
		<views:WorkspaceSettingsView DataContext="{Binding Settings}" />

		<!-- New-workspace dialog. Bound directly to the SettingsViewModel; manages its own visibility
		     (scrim IsVisible = NewWorkspaceOpen) and layers above everything else. -->
		<views:NewWorkspaceView DataContext="{Binding Settings}" />
	</Panel>
</Window>
