<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:MaxwellCalc.Notebook.ViewModels"
        xmlns:controls="using:MaxwellCalc.Notebook.Controls"
        xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        mc:Ignorable="d" d:DesignWidth="820" d:DesignHeight="620"
        Width="820" Height="620" MinWidth="560" MinHeight="360"
        x:Class="MaxwellCalc.Notebook.Views.ShellWindow"
        x:DataType="vm:ShellViewModel"
        ExtendClientAreaToDecorationsHint="True"
        WindowDecorations="BorderOnly"
        Background="{DynamicResource BgBrush}"
        Title="MaxwellCalc">

	<Window.Styles>
		<!-- Custom window caption buttons (min / max-restore / close) and the theme toggle.
		     Flush to the top-right, 46x44, transparent with a subtle hover; close hovers red. -->
		<Style Selector="Button.caption">
			<Setter Property="Width" Value="46" />
			<Setter Property="Height" Value="44" />
			<Setter Property="Padding" Value="0" />
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="CornerRadius" Value="0" />
			<Setter Property="VerticalAlignment" Value="Stretch" />
			<Setter Property="Foreground" Value="{DynamicResource MutBrush}" />
		</Style>
		<Style Selector="Button.caption /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="CornerRadius" Value="0" />
		</Style>
		<Style Selector="Button.caption:pointerover /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="{DynamicResource LineBrush}" />
		</Style>
		<Style Selector="Button.caption:pointerover">
			<Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
		</Style>
		<Style Selector="Button.caption.close:pointerover /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="{DynamicResource ErrBrush}" />
		</Style>
		<Style Selector="Button.caption.close:pointerover">
			<Setter Property="Foreground" Value="White" />
		</Style>

		<!-- Settings flyout: section caption + unit-hue swatch buttons. -->
		<Style Selector="TextBlock.settingsLabel">
			<Setter Property="FontFamily" Value="{DynamicResource UiFontFamily}" />
			<Setter Property="FontSize" Value="10.5" />
			<Setter Property="FontWeight" Value="SemiBold" />
			<Setter Property="Foreground" Value="{DynamicResource FaintBrush}" />
		</Style>
		<!-- Chrome-less button wrapping a color swatch (kept transparent in every state). -->
		<Style Selector="Button.hueBtn">
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="Padding" Value="0" />
			<Setter Property="CornerRadius" Value="6" />
			<Setter Property="Cursor" Value="Hand" />
		</Style>
		<Style Selector="Button.hueBtn /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="Transparent" />
		</Style>
		<Style Selector="Button.hueBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="Transparent" />
		</Style>
		<Style Selector="Button.hueBtn:pressed /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="Transparent" />
		</Style>
		<!-- The swatch itself: a rounded color chip with a ring that darkens when selected. -->
		<Style Selector="Border.swatch">
			<Setter Property="Width" Value="34" />
			<Setter Property="Height" Value="24" />
			<Setter Property="CornerRadius" Value="6" />
			<Setter Property="BorderThickness" Value="2" />
			<Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
		</Style>
		<Style Selector="Border.swatch.active">
			<Setter Property="BorderBrush" Value="{DynamicResource InkBrush}" />
		</Style>
	</Window.Styles>

	<!-- Global shortcuts: ⌘K / Ctrl+K opens the command palette on the Units section; Esc closes it
	     (a no-op when already closed). The line editor only handles unmodified Enter/Backspace/arrows,
	     so Ctrl+K bubbles up to here. -->
	<Window.KeyBindings>
		<KeyBinding Gesture="Ctrl+K" Command="{Binding CommandPalette.OpenUnitsCommand}" />
		<KeyBinding Gesture="Meta+K" Command="{Binding CommandPalette.OpenUnitsCommand}" />
		<KeyBinding Gesture="Escape" Command="{Binding CommandPalette.CloseCommand}" />
	</Window.KeyBindings>

	<!-- Three-region single-window shell (title bar / sheet / access bar) with the command-palette
	     overlay layered on top (Step 8). The overlay's scrim spans the whole window; when closed it is
	     collapsed and transparent to hit-testing so the shell underneath stays interactive. -->
	<Panel>
	<Grid RowDefinitions="Auto,*,Auto">

		<!-- ============================ TITLE BAR ============================ -->
		<Border Grid.Row="0"
				Name="TitleBar"
				Height="{DynamicResource TitleBarHeight}"
				Background="{DynamicResource BarBrush}"
				BorderBrush="{DynamicResource LineBrush}"
				BorderThickness="0,0,0,1"
				PointerPressed="OnTitleBarPointerPressed">
			<Grid ColumnDefinitions="Auto,*,Auto" Margin="14,0,0,0">

				<!-- Left cluster: app mark + name + workspace caption (gap 10). -->
				<StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10"
							VerticalAlignment="Center">
					<Border Width="15" Height="15"
							CornerRadius="{DynamicResource AppMarkCornerRadius}"
							Background="{DynamicResource AccentBrush}" />
					<TextBlock Text="MaxwellCalc"
							   FontFamily="{DynamicResource UiFontFamily}"
							   FontSize="12.5" FontWeight="SemiBold"
							   Foreground="{DynamicResource InkBrush}"
							   VerticalAlignment="Center" />
					<TextBlock Text="{Binding WorkspaceName, StringFormat='— {0}'}"
							   FontFamily="{DynamicResource UiFontFamily}"
							   FontSize="11"
							   Foreground="{DynamicResource FaintBrush}"
							   VerticalAlignment="Center" />
				</StackPanel>

				<!-- Right cluster: theme toggle + custom window caption buttons. We use
				     SystemDecorations="BorderOnly" (native resize border + shadow, no native
				     title/buttons), so the min/max/close buttons are drawn and wired here. -->
				<StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Stretch">
					<!-- Settings: unit-hue swatches + the auto-caption toggle. -->
					<Button Classes="caption" ToolTip.Tip="Settings">
						<materialIcons:MaterialIcon Kind="Cog" Width="16" Height="16" />
						<Button.Flyout>
							<Flyout Placement="BottomEdgeAlignedRight">
								<StackPanel Width="230" Spacing="12" Margin="4,6">
									<TextBlock Classes="settingsLabel" Text="UNIT COLOR" />
									<StackPanel Orientation="Horizontal" Spacing="10">
										<Button Classes="hueBtn"
												Command="{Binding Settings.SetUnitHueCommand}"
												CommandParameter="{x:Static vm:UnitHue.Amber}"
												ToolTip.Tip="Amber">
											<Border Classes="swatch" Classes.active="{Binding Settings.IsAmber}"
													Background="{DynamicResource UnitHueAmberBrush}" />
										</Button>
										<Button Classes="hueBtn"
												Command="{Binding Settings.SetUnitHueCommand}"
												CommandParameter="{x:Static vm:UnitHue.Green}"
												ToolTip.Tip="Green">
											<Border Classes="swatch" Classes.active="{Binding Settings.IsGreen}"
													Background="{DynamicResource UnitHueGreenBrush}" />
										</Button>
										<Button Classes="hueBtn"
												Command="{Binding Settings.SetUnitHueCommand}"
												CommandParameter="{x:Static vm:UnitHue.Violet}"
												ToolTip.Tip="Violet">
											<Border Classes="swatch" Classes.active="{Binding Settings.IsViolet}"
													Background="{DynamicResource UnitHueVioletBrush}" />
										</Button>
									</StackPanel>
									<CheckBox IsChecked="{Binding Settings.AutoCaptionEnabled}"
											  FontFamily="{DynamicResource UiFontFamily}"
											  FontSize="12"
											  Foreground="{DynamicResource InkBrush}"
											  Content="Auto-select output unit caption" />
								</StackPanel>
							</Flyout>
						</Button.Flyout>
					</Button>
					<Button Command="{Binding Settings.ToggleThemeCommand}"
							Classes="caption"
							Margin="0,0,6,0"
							ToolTip.Tip="Toggle light / dark">
						<materialIcons:MaterialIcon Kind="{Binding Settings.ThemeToggleIcon}" Width="16" Height="16" />
					</Button>
					<Button Classes="caption" Click="OnMinimize" ToolTip.Tip="Minimize">
						<materialIcons:MaterialIcon Kind="WindowMinimize" Width="15" Height="15" />
					</Button>
					<Button Classes="caption" Click="OnMaximizeRestore" ToolTip.Tip="Maximize">
						<materialIcons:MaterialIcon Name="MaxRestoreIcon" Kind="WindowMaximize"
													Width="14" Height="14" />
					</Button>
					<Button Classes="caption close" Click="OnClose" ToolTip.Tip="Close">
						<materialIcons:MaterialIcon Kind="WindowClose" Width="15" Height="15" />
					</Button>
				</StackPanel>
			</Grid>
		</Border>

		<!-- ============================ SHEET REGION ============================ -->
		<!-- The live notebook sheet. SheetView renders one editable row per line with its result
		     gutter (Step 5); resolved via the ViewLocator from ShellViewModel.Sheet. -->
		<ScrollViewer Grid.Row="1" Background="{DynamicResource SurfBrush}"
					  HorizontalScrollBarVisibility="Disabled">
			<ContentControl Content="{Binding Sheet}" />
		</ScrollViewer>

		<!-- ============================ ACCESS BAR ============================ -->
		<Border Grid.Row="2"
				Background="{DynamicResource BarFooterBrush}"
				BorderBrush="{DynamicResource LineBrush}"
				BorderThickness="0,1,0,0"
				Padding="{DynamicResource AccessBarPadding}">
			<Grid ColumnDefinitions="Auto,*,Auto">

				<!-- Physics ▾ button + divider + chips (gap 9). -->
				<StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="9"
							VerticalAlignment="Center">
					<Button Background="{DynamicResource AccentBrush}"
							Foreground="White"
							BorderThickness="0"
							CornerRadius="{DynamicResource ButtonCornerRadius}"
							Padding="11,6"
							ToolTip.Tip="Switch workspace">
						<StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
							<TextBlock Text="{Binding WorkspaceName}"
									   FontFamily="{DynamicResource UiFontFamily}"
									   FontSize="12" FontWeight="SemiBold"
									   VerticalAlignment="Center" />
							<materialIcons:MaterialIcon Kind="MenuDown" Width="15" Height="15"
														VerticalAlignment="Center" />
						</StackPanel>
						<!-- Workspace switcher. MenuItems bind their own SelectCommand (per-entry), so no
						     binding needs to cross the flyout popup back to the shell data context. -->
						<Button.Flyout>
							<MenuFlyout ItemsSource="{Binding Settings.Workspaces}">
								<MenuFlyout.ItemContainerTheme>
									<ControlTheme TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}"
												  x:DataType="vm:WorkspaceEntry">
										<Setter Property="Header" Value="{Binding Name}" />
										<Setter Property="Command" Value="{Binding SelectCommand}" />
									</ControlTheme>
								</MenuFlyout.ItemContainerTheme>
							</MenuFlyout>
						</Button.Flyout>
					</Button>

					<Border Width="1" Height="20" Background="{DynamicResource LineBrush}"
							VerticalAlignment="Center" Margin="3,0" />

					<controls:Chip Glyph="x" GlyphFontStyle="Italic"
								   GlyphForeground="{DynamicResource AccentBrush}"
								   Label="Variables" Count="{Binding CommandPalette.Variables.Count}"
								   Command="{Binding CommandPalette.OpenVariablesCommand}" />
					<controls:Chip Glyph="m"
								   GlyphForeground="{DynamicResource UnitHueBrush}"
								   Label="Units" Count="{Binding CommandPalette.InputUnits.Count}"
								   Command="{Binding CommandPalette.OpenUnitsCommand}" />
					<controls:Chip Glyph="f" GlyphFontStyle="Italic"
								   GlyphForeground="{DynamicResource AccentBrush}"
								   Label="Functions" Count="{Binding CommandPalette.Functions.Count}"
								   Command="{Binding CommandPalette.OpenFunctionsCommand}" />
				</StackPanel>

				<!-- ⌘K key-hint pill at far right. -->
				<Border Grid.Column="2"
						Background="{DynamicResource ChipBrush}"
						BorderBrush="{DynamicResource ChipBorderBrush}"
						BorderThickness="1"
						CornerRadius="{DynamicResource ChipCornerRadius}"
						Padding="9,4"
						VerticalAlignment="Center">
					<TextBlock Text="⌘K"
							   FontFamily="{DynamicResource MonoFontFamily}"
							   FontSize="11.5"
							   Foreground="{DynamicResource MutBrush}" />
				</Border>
			</Grid>
		</Border>
	</Grid>

		<!-- Command-palette overlay, resolved to CommandPaletteView via the ViewLocator. It manages its
		     own visibility (scrim IsVisible = PaletteOpen), so it stays here spanning the whole window. -->
		<ContentControl Content="{Binding CommandPalette}" />
	</Panel>
</Window>
