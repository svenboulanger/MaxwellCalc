<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MaxwellCalc.Notebook.ViewModels"
             xmlns:controls="using:MaxwellCalc.Notebook.Controls"
             mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="400"
             x:Class="MaxwellCalc.Notebook.Views.SheetView"
             x:DataType="vm:SheetViewModel">

	<!-- Step 6 — the notebook sheet: one row per line, the inline-highlighting editor on the left and
	     the result gutter on the right. The editor is the HighlightedExpressionBox; Step 7 adds the
	     Enter/Backspace/Arrow keyboard model. -->
	<UserControl.Styles>
		<!-- Row: padding 8/26, 1px bottom hairline, focused row gets a subtle accent wash with a
		     120ms background transition. -->
		<Style Selector="Border.row">
			<Setter Property="Padding" Value="{DynamicResource RowPadding}" />
			<Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
			<Setter Property="BorderThickness" Value="0,0,0,1" />
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="Transitions">
				<Transitions>
					<BrushTransition Property="Background" Duration="0:0:0.12" />
				</Transitions>
			</Setter>
		</Style>
		<Style Selector="Border.row:focus-within">
			<Setter Property="Background" Value="{DynamicResource ActiveTintBrush}" />
		</Style>

		<!-- Auto-caption: tiny faint sans caption under the focused row when the output unit was
		     auto-selected. Right-aligned to sit under the gutter value. -->
		<Style Selector="TextBlock.autoCaption">
			<Setter Property="FontFamily" Value="{DynamicResource UiFontFamily}" />
			<Setter Property="FontSize" Value="10.5" />
			<Setter Property="Foreground" Value="{DynamicResource FaintBrush}" />
			<Setter Property="TextAlignment" Value="Right" />
			<Setter Property="HorizontalAlignment" Value="Right" />
		</Style>

		<!-- Error: err color, 12.5px sans (not mono), ⚠ prefix, right-aligned and wrapping. -->
		<Style Selector="TextBlock.error">
			<Setter Property="FontFamily" Value="{DynamicResource UiFontFamily}" />
			<Setter Property="FontSize" Value="12.5" />
			<Setter Property="Foreground" Value="{DynamicResource ErrBrush}" />
			<Setter Property="TextWrapping" Value="Wrap" />
			<Setter Property="TextAlignment" Value="Right" />
			<Setter Property="MaxWidth" Value="340" />
			<Setter Property="VerticalAlignment" Value="Center" />
		</Style>
	</UserControl.Styles>

	<ItemsControl Name="LinesHost" ItemsSource="{Binding Lines}">
		<ItemsControl.ItemTemplate>
			<DataTemplate x:DataType="vm:LineViewModel">
				<Border Classes="row">
					<StackPanel Spacing="2">
						<Grid ColumnDefinitions="*,Auto" ColumnSpacing="24">

							<!-- Editor (left, fills): inline syntax highlighting driven by the active
							     workspace, which lives on the SheetViewModel (the view's DataContext).
							     The Enter/Backspace/Arrow events drive the notebook keyboard model. -->
							<controls:HighlightedExpressionBox Grid.Column="0"
									Text="{Binding Text, Mode=TwoWay}"
									CaretIndex="{Binding CaretIndex, Mode=TwoWay}"
									Workspace="{Binding ((vm:SheetViewModel)DataContext).Workspace, RelativeSource={RelativeSource AncestorType=UserControl}}"
									GotFocus="OnEditorGotFocus"
									LostFocus="OnEditorLostFocus"
									EnterPressed="OnEnterPressed"
									MergeBackRequested="OnMergeBackRequested"
									MergeForwardRequested="OnMergeForwardRequested"
									NavigateUpRequested="OnNavigateUpRequested"
									NavigateDownRequested="OnNavigateDownRequested" />

							<!-- Result gutter (right). Exactly one branch is visible per line. -->
							<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
										HorizontalAlignment="Right" VerticalAlignment="Center">

								<!-- const pill, shown before the value when the line is a lone constant. -->
								<Border Classes="constPill" IsVisible="{Binding IsConstBadge}">
									<TextBlock Text="const" />
								</Border>

								<!-- value / assignment: the formatted quantity. Clicking copies it to the
								     clipboard in original text form (e-exponent scalar, ^-notation units). -->
								<controls:QuantityView Value="{Binding Quantity}"
													   IsVisible="{Binding HasValue}"
													   CopyOnClick="True" />

								<!-- function definition. -->
								<Border Classes="funcPill" IsVisible="{Binding IsFuncDef}">
									<TextBlock Text="ƒ defined" />
								</Border>

								<!-- error. -->
								<TextBlock Classes="error" IsVisible="{Binding IsError}"
										   Text="{Binding ErrorMessage, StringFormat='⚠ {0}'}" />
							</StackPanel>
						</Grid>

						<!-- Auto-caption under the row: shown when the row is focused, its output unit was
						     auto-selected, AND the user setting is on (SheetViewModel.AutoCaptionEnabled,
						     driven by SettingsViewModel — Step 10). -->
						<TextBlock Classes="autoCaption"
								   Text="output unit auto-selected (value ≥ 1) — type `in &lt;unit&gt;` to override">
							<TextBlock.IsVisible>
								<MultiBinding Converter="{x:Static BoolConverters.And}">
									<Binding Path="ShowAutoCaption" />
									<Binding Path="((vm:SheetViewModel)DataContext).AutoCaptionEnabled"
											 RelativeSource="{RelativeSource AncestorType=UserControl}" />
								</MultiBinding>
							</TextBlock.IsVisible>
						</TextBlock>
					</StackPanel>
				</Border>
			</DataTemplate>
		</ItemsControl.ItemTemplate>
	</ItemsControl>
</UserControl>
