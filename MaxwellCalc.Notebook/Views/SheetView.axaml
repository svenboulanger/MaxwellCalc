<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MaxwellCalc.Notebook.ViewModels"
             xmlns:controls="using:MaxwellCalc.Notebook.Controls"
             mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="400"
             x:Class="MaxwellCalc.Notebook.Views.SheetView"
             x:DataType="vm:SheetViewModel">

	<!-- Step 5 — the notebook sheet: one row per line, editor on the left and the result gutter on
	     the right. The editor is a plain (unhighlighted) TextBox for now; Step 6 swaps in the
	     HighlightedExpressionBox and Step 7 adds the keyboard model. The gutter rendering is the
	     focus of this step. -->
	<UserControl.Styles>
		<!-- Row: padding 8/26, 1px bottom hairline, focused row gets a subtle accent wash with a
		     120ms background transition. -->
		<Style Selector="Border.row">
			<Setter Property="Padding" Value="{DynamicResource RowPadding}" />
			<Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
			<Setter Property="BorderThickness" Value="0,0,0,1" />
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="Transitions">
				<Transitions>
					<BrushTransition Property="Background" Duration="0:0:0.12" />
				</Transitions>
			</Setter>
		</Style>
		<Style Selector="Border.row:focus-within">
			<Setter Property="Background" Value="{DynamicResource ActiveTintBrush}" />
		</Style>

		<!-- Editor: transparent, borderless, mono 15px/400, ink; accent caret. -->
		<Style Selector="TextBox.editor">
			<Setter Property="FontFamily" Value="{DynamicResource MonoFontFamily}" />
			<Setter Property="FontSize" Value="{DynamicResource EditorFontSize}" />
			<Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
			<Setter Property="CaretBrush" Value="{DynamicResource AccentBrush}" />
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="Padding" Value="0" />
			<Setter Property="MinHeight" Value="0" />
			<Setter Property="VerticalAlignment" Value="Center" />
			<Setter Property="VerticalContentAlignment" Value="Center" />
		</Style>
		<Style Selector="TextBox.editor /template/ Border#PART_BorderElement">
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="BorderThickness" Value="0" />
		</Style>
		<Style Selector="TextBox.editor:pointerover /template/ Border#PART_BorderElement">
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="BorderThickness" Value="0" />
		</Style>
		<Style Selector="TextBox.editor:focus /template/ Border#PART_BorderElement">
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="BorderThickness" Value="0" />
		</Style>

		<!-- Error: err color, 12.5px sans (not mono), ⚠ prefix, right-aligned and wrapping. -->
		<Style Selector="TextBlock.error">
			<Setter Property="FontFamily" Value="{DynamicResource UiFontFamily}" />
			<Setter Property="FontSize" Value="12.5" />
			<Setter Property="Foreground" Value="{DynamicResource ErrBrush}" />
			<Setter Property="TextWrapping" Value="Wrap" />
			<Setter Property="TextAlignment" Value="Right" />
			<Setter Property="MaxWidth" Value="340" />
			<Setter Property="VerticalAlignment" Value="Center" />
		</Style>
	</UserControl.Styles>

	<ItemsControl ItemsSource="{Binding Lines}">
		<ItemsControl.ItemTemplate>
			<DataTemplate x:DataType="vm:LineViewModel">
				<Border Classes="row">
					<Grid ColumnDefinitions="*,Auto" ColumnSpacing="24">

						<!-- Editor (left, fills). -->
						<TextBox Grid.Column="0" Classes="editor"
								 Text="{Binding Text, Mode=TwoWay}" />

						<!-- Result gutter (right). Exactly one branch is visible per line. -->
						<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
									HorizontalAlignment="Right" VerticalAlignment="Center">

							<!-- const pill, shown before the value when the line is a lone constant. -->
							<Border Classes="constPill" IsVisible="{Binding IsConstBadge}">
								<TextBlock Text="const" />
							</Border>

							<!-- value / assignment: the formatted quantity. -->
							<controls:QuantityView Value="{Binding Quantity}"
												   IsVisible="{Binding HasValue}" />

							<!-- function definition. -->
							<Border Classes="funcPill" IsVisible="{Binding IsFuncDef}">
								<TextBlock Text="ƒ defined" />
							</Border>

							<!-- error. -->
							<TextBlock Classes="error" IsVisible="{Binding IsError}"
									   Text="{Binding ErrorMessage, StringFormat='⚠ {0}'}" />
						</StackPanel>
					</Grid>
				</Border>
			</DataTemplate>
		</ItemsControl.ItemTemplate>
	</ItemsControl>
</UserControl>
